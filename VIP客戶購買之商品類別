SELECT *
  FROM (
           SELECT [Customer ID],
                  [Customer Name],
                   Category,
                  [Sub-Category],
                  SUM(Sales) AS total_sales,
                  SUM(Profit) AS total_profit
             FROM superstore
            GROUP BY [Customer ID],
                     [Sub-Category]
            ORDER BY [Customer ID]
       )
 WHERE [Customer ID] IN (
           SELECT [Customer ID]
             FROM (
                      SELECT *,
                             SUM(Sales) AS total_sales,
                             PERCENT_RANK() OVER (ORDER BY SUM(Sales) DESC) AS p_rank
                        FROM superstore
                       GROUP BY [Customer ID]
                       ORDER BY total_sales DESC
                  )
            WHERE p_rank <= 0.2
       );
